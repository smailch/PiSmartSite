# Copier vers .env.local (recommandé pour Next.js) et remplir les valeurs.
# Les fichiers .env.local ne sont pas commités.

# URL de l’API NestJS (sans slash final)
NEXT_PUBLIC_API_URL=http://localhost:3200

# Génération de tâches suggérées (route /api/gemini/generate-tasks — OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# Debug / routes Gemini optionnelles (si prévu dans le projet)
# REACT_APP_GEMINI_API_KEY=your_gemini_key_here
