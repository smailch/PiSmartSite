# Public API base (Vercel / production: your Railway Nest URL, no trailing slash)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3200

# Server-side Next routes only: override if the backend URL differs from NEXT_PUBLIC_API_URL (e.g. Docker network)
# INTERNAL_API_URL=

# Optional AI analysis URL if used from Next API routes
# AI_ANALYSIS_URL=
