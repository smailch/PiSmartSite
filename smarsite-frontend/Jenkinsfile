/**
 * PiSmartSite — CI Frontend (Next.js)
 * Job Jenkins : Script Path = smarsite-frontend/Jenkinsfile
 * Prérequis : Linux (curl, tar). Node auto-installé dans .ci-tools/node si absent.
 * Définir la variable de job NEXT_PUBLIC_API_URL (ou laisser le défaut ci-dessous).
 */
pipeline {
  agent any

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  environment {
    CI = 'true'
    HUSKY = '0'
    NEXT_TELEMETRY_DISABLED = '1'
    // Surchargeable dans la config du job Jenkins
    NEXT_PUBLIC_API_URL = "${env.NEXT_PUBLIC_API_URL ?: 'http://127.0.0.1:3200'}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Bootstrap Node') {
      steps {
        sh '''
          set -e
          if command -v node >/dev/null 2>&1; then exit 0; fi
          NODE_VER=22.12.0
          ARCH=x64
          case "$(uname -m)" in aarch64|arm64) ARCH=arm64 ;; esac
          DEST="${WORKSPACE}/.ci-tools/node"
          mkdir -p "${WORKSPACE}/.ci-tools"
          if [ -x "${DEST}/bin/node" ]; then exit 0; fi
          TMP="/tmp/node-ci-$$.tar.gz"
          curl -fsSL "https://nodejs.org/dist/v${NODE_VER}/node-v${NODE_VER}-linux-${ARCH}.tar.gz" -o "${TMP}"
          rm -rf "${DEST}" && mkdir -p "${DEST}"
          tar -xzf "${TMP}" -C "${DEST}" --strip-components=1
          rm -f "${TMP}"
        '''
        script {
          if (fileExists('.ci-tools/node/bin/node')) {
            env.PATH = "${env.WORKSPACE}/.ci-tools/node/bin:${env.PATH}"
          }
        }
      }
    }

    stage('Toolchain') {
      steps {
        sh 'node -v && npm -v'
      }
    }

    stage('Install') {
      steps {
        dir('smarsite-frontend') {
          sh 'echo ">>> npm ci (frontend)" && npm ci'
        }
      }
    }

    stage('Unit tests + coverage') {
      steps {
        sh 'mkdir -p reports/junit'
        dir('smarsite-frontend') {
          sh 'echo ">>> npm run test:cov:ci (échec = pipeline rouge)" && npm run test:cov:ci'
        }
      }
      post {
        always {
          junit testResults: 'reports/junit/**/*.xml', allowEmptyResults: true
        }
      }
    }

    stage('Build') {
      steps {
        dir('smarsite-frontend') {
          sh 'echo ">>> npm run build" && npm run build'
        }
      }
    }
  }

  post {
    success {
      echo 'CI Frontend : SUCCESS — prêt pour enchaînement CD.'
    }
    failure {
      echo 'CI Frontend : FAILURE — corriger les tests ou le build.'
    }
    always {
      dir('smarsite-frontend') {
        archiveArtifacts artifacts: 'coverage/**/*', allowEmptyArchive: true
      }
    }
  }
}
