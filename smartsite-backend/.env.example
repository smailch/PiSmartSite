# MongoDB Atlas (required in production)
MONGO_URI=
# Alias also supported: MONGODB_URI, SMARTSITE_MONGODB_URI

# Server (Railway injects PORT)
PORT=3200
LISTEN_HOST=0.0.0.0

# CORS: comma-separated origins (required for browser clients, e.g. Vercel frontend)
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=

# Optional FastAPI / image analysis service
AI_ANALYSIS_URL=http://127.0.0.1:8001/analyze-image

# Node
NODE_ENV=development
