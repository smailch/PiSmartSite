# Copier vers .env et renseigner les vraies valeurs (ne pas committer .env).
# Groq : https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_FALLBACK=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=10000

# MongoDB (si vous externalisez la chaîne depuis app.module)
# MONGODB_URI=mongodb://127.0.0.1:27017/smartsite

# Bot Telegram (optionnel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Analyse sécurité chantier (photos d’avancement job) — smartsite-ai-service (port 8001)
# AI_ANALYSIS_URL=http://127.0.0.1:8001/analyze-image
