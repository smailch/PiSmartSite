# MongoDB Atlas (required in production)
MONGO_URI=
# Aliases: MONGODB_URI, SMARTSITE_MONGODB_URI, MONGO_URL (Railway Mongo template), DATABASE_URL if mongodb://…

# Server — Railway injecte PORT (obligatoire en prod). En local seulement, ex. 3200.
# L’écoute est toujours sur 0.0.0.0 (plus de LISTEN_HOST).
PORT=3200

# CORS: comma-separated origins (required for browser clients, e.g. Vercel frontend)
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=

# Optional FastAPI / image analysis service
AI_ANALYSIS_URL=http://127.0.0.1:8001/analyze-image

# Node
NODE_ENV=development

# Telegram : un seul process peut faire du long polling par bot. Sur Railway, mettre true
# si ton PC local (ou un 2e déploiement) lance déjà le bot avec le même TELEGRAM_BOT_TOKEN.
# TELEGRAM_DISABLE_POLLING=true
