# Copier vers .env et renseigner les valeurs : cp .env.example .env
# Groq : https://console.groq.com/
GROQ_API_KEY=
GROQ_API_KEY_FALLBACK=
GROQ_MODEL=llama-3.1-8b-instant
# Modèle vision (photos chantier / progress-photos) — liste : console Groq
GROQ_VISION_MODEL=meta-llama/llama-3.2-11b-vision-preview
GROQ_TIMEOUT_MS=10000
OPENROUTER_API_KEY=

# MongoDB (si pris en charge par votre app.module)
# MONGODB_URI=mongodb://127.0.0.1:27017/smartsite

# Bot Telegram (optionnel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
