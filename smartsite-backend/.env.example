# Copier ce fichier vers .env et remplir les valeurs (le fichier .env reste ignoré par Git).
# Clé Groq : https://console.groq.com/ — requis pour l’analyse projet et l’assistant (analysis-ai).
GROQ_API_KEY=your_groq_api_key_here

# Optionnel
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=10000

# MongoDB (si pris en charge par votre app.module)
# MONGODB_URI=mongodb://127.0.0.1:27017/smartsite
