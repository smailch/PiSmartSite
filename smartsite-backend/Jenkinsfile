/**
 * PiSmartSite — CI Backend (NestJS)
 * Job Jenkins : charger ce fichier via « Pipeline script from SCM », Script Path = smartsite-backend/Jenkinsfile
 * Prérequis : Linux (curl, tar), Git. Node auto-installé dans .ci-tools/node si absent.
 */
pipeline {
  agent any

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  environment {
    CI = 'true'
    HUSKY = '0'
    // Aligné sur .github/workflows/backend-ci.yml
    JEST_JUNIT_OUTPUT_DIR = "${WORKSPACE}/reports/junit"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Bootstrap Node') {
      steps {
        sh '''
          set -e
          if command -v node >/dev/null 2>&1; then exit 0; fi
          NODE_VER=22.12.0
          ARCH=x64
          case "$(uname -m)" in aarch64|arm64) ARCH=arm64 ;; esac
          DEST="${WORKSPACE}/.ci-tools/node"
          mkdir -p "${WORKSPACE}/.ci-tools"
          if [ -x "${DEST}/bin/node" ]; then exit 0; fi
          TMP="/tmp/node-ci-$$.tar.gz"
          curl -fsSL "https://nodejs.org/dist/v${NODE_VER}/node-v${NODE_VER}-linux-${ARCH}.tar.gz" -o "${TMP}"
          rm -rf "${DEST}" && mkdir -p "${DEST}"
          tar -xzf "${TMP}" -C "${DEST}" --strip-components=1
          rm -f "${TMP}"
        '''
        script {
          if (fileExists('.ci-tools/node/bin/node')) {
            env.PATH = "${env.WORKSPACE}/.ci-tools/node/bin:${env.PATH}"
          }
        }
      }
    }

    stage('Toolchain') {
      steps {
        sh 'node -v && npm -v'
      }
    }

    stage('Install') {
      steps {
        dir('smartsite-backend') {
          sh 'echo ">>> npm ci (backend)" && npm ci'
        }
      }
    }

    stage('Unit tests + coverage') {
      steps {
        sh 'mkdir -p reports/junit'
        dir('smartsite-backend') {
          sh 'echo ">>> npm run test:cov:ci (échec = pipeline rouge)" && npm run test:cov:ci'
        }
      }
      post {
        always {
          junit testResults: 'reports/junit/**/*.xml', allowEmptyResults: true
        }
      }
    }

    stage('Build') {
      steps {
        dir('smartsite-backend') {
          sh 'echo ">>> npm run build" && npm run build'
        }
      }
    }
  }

  post {
    success {
      echo 'CI Backend : SUCCESS — prêt pour enchaînement CD (job déclenché après ce projet).'
    }
    failure {
      echo 'CI Backend : FAILURE — corriger les tests ou le build avant tout déploiement.'
    }
    always {
      dir('smartsite-backend') {
        archiveArtifacts artifacts: 'coverage/**/*', allowEmptyArchive: true
      }
    }
  }
}
