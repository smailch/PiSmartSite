# Copier depuis .env.example et renseigner les clés (équipe : partage hors Git si besoin).
GROQ_API_KEY=
GROQ_API_KEY_FALLBACK=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=10000

# Telegram (@BotFather → API Token). Sans token, le bot ne démarre pas.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=SmartSite_Project_bot
